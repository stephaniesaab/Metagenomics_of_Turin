#Get the Accession list into a txt (downloaded as a CSV from NCBI) and clean the header
cut -d ',' -f 1 SraAccList.csv > sra_list.txt

#Take off header
sed -i '1d' sra_list.txt

#Download with sra sratoolkit
prefetch --option-file sra_list.txt

#Watch the download:
watch -n 5 "ls -lh ."

#Move the SRA files to a directory in the repo: SRA_files
mkrdir SRA_files
for id in $(cat sra_list.txt); do
    mv ${id}/${id}.sra ./SRA_files/
done

